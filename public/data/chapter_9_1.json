                }
            ],
            "body": [
                {
                    "type": "instruction_text",
                    "text": {
                        "en": "Simplify the expression.",
                        "uz": "Ifodani soddalashtiring.",
                        "ru": "Упростите выражение."
                    }
                },
                {
                    "type": "question_grid",
                    "columns": 2,
                    "items": [
                        {
                            "id": "sa_q1",
                            "label": "1.",
                            "latex": "\\sqrt{24}"
                        },
